{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "saude-publica-br — Métricas de API (FastAPI + nginx)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 Visão Geral",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Requisições/s",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{job=\"fastapi\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Latência P95",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[5m])) by (le))",
          "legendFormat": "P95"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Taxa de Erro (5xx)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{job=\"fastapi\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"fastapi\"}[5m]))",
          "legendFormat": "error rate"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Requisições em Andamento",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(http_requests_in_progress{job=\"fastapi\"})",
          "legendFormat": "in-flight"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📈 Throughput & Latência",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Requisições/s por Status",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{job=\"fastapi\"}[1m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Latência por Percentil (5m)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "🔍 Por Endpoint",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Req/s por Rota (Top 10)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "topk(10, sum(rate(http_requests_total{job=\"fastapi\"}[1m])) by (handler))",
          "legendFormat": "{{handler}}"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Latência P95 por Rota",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[5m])) by (le, handler))",
          "legendFormat": "{{handler}}"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "⚡ Cache Redis",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Cache Hits vs Misses/s",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(api_cache_hits_total{job=\"fastapi\"}[1m]))",
          "legendFormat": "hits/s"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(api_cache_misses_total{job=\"fastapi\"}[1m]))",
          "legendFormat": "misses/s"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Cache Hit Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(api_cache_hits_total{job=\"fastapi\"}[5m])) / (sum(rate(api_cache_hits_total{job=\"fastapi\"}[5m])) + sum(rate(api_cache_misses_total{job=\"fastapi\"}[5m])))",
          "legendFormat": "hit rate"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "🌐 nginx",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 40,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "nginx — Conexões Ativas",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nginx_connections_active{job=\"nginx\"}",
          "legendFormat": "active"
        },
        {
          "datasource": "Prometheus",
          "expr": "nginx_connections_waiting{job=\"nginx\"}",
          "legendFormat": "waiting"
        },
        {
          "datasource": "Prometheus",
          "expr": "nginx_connections_reading{job=\"nginx\"}",
          "legendFormat": "reading"
        },
        {
          "datasource": "Prometheus",
          "expr": "nginx_connections_writing{job=\"nginx\"}",
          "legendFormat": "writing"
        }
      ]
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 41,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "nginx — Requisições/s",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(nginx_http_requests_total{job=\"nginx\"}[1m])",
          "legendFormat": "requests/s"
        }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["saude-publica-br", "fastapi", "nginx"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "America/Sao_Paulo",
  "title": "saude-publica-br — API & Infrastructure",
  "uid": "saude-publica-br-api",
  "version": 1
}
